---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0D0D0D] text-[#F8F8F5] mt-auto">
  <div class="max-w-[1280px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <span class="font-playfair font-bold text-2xl tracking-[0.15em] uppercase text-[#F8F8F5]">
          Sapiens
        </span>
        <p class="mt-4 text-sm font-inter text-[#8A8A8A] leading-relaxed">
          Tu librería peruana de confianza. Libros y revistas con entrega en Lima y provincias.
        </p>
      </div>

      <!-- Catálogo -->
      <div>
        <h3 class="text-xs font-inter font-semibold tracking-widest uppercase text-[#8A8A8A] mb-4">Catálogo</h3>
        <ul class="flex flex-col gap-3">
          <li><a href="/catalogo/libros" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Libros</a></li>
          <li><a href="/catalogo/revistas" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Revistas</a></li>
          <li><a href="/categorias" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Categorías</a></li>
          <li><a href="/autores" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Autores</a></li>
        </ul>
      </div>

      <!-- Ayuda -->
      <div>
        <h3 class="text-xs font-inter font-semibold tracking-widest uppercase text-[#8A8A8A] mb-4">Ayuda</h3>
        <ul class="flex flex-col gap-3">
          <li><a href="/ayuda" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Centro de ayuda</a></li>
          <li><a href="/politicas/envios" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Política de envíos</a></li>
          <li><a href="/politicas/devoluciones" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Devoluciones</a></li>
          <li><a href="/mi-cuenta/pedidos" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">Mis pedidos</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-xs font-inter font-semibold tracking-widest uppercase text-[#8A8A8A] mb-4">Contacto</h3>
        <ul class="flex flex-col gap-3">
          <li class="text-sm font-inter text-[#8A8A8A]">Lima, Perú</li>
          <li>
            <a href="mailto:hola@sapiens.pe" class="text-sm font-inter text-[#F8F8F5] hover:text-accent transition-colors">
              hola@sapiens.pe
            </a>
          </li>
          <li class="text-sm font-inter text-[#8A8A8A]">Lun–Vie, 9am–6pm</li>
        </ul>
        <!-- Redes -->
        <div class="flex gap-4 mt-6">
          <a href="#" aria-label="Sapiens en Instagram" class="text-[#8A8A8A] hover:text-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="Sapiens en Facebook" class="text-[#8A8A8A] hover:text-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[#2A2A2A] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs font-inter text-[#8A8A8A]">
        &copy; {currentYear} Sapiens. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="/politicas/envios" class="text-xs font-inter text-[#8A8A8A] hover:text-[#F8F8F5] transition-colors">Envíos</a>
        <a href="/politicas/devoluciones" class="text-xs font-inter text-[#8A8A8A] hover:text-[#F8F8F5] transition-colors">Devoluciones</a>
      </div>
    </div>
  </div>
</footer>
