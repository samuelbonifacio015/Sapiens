---
const navLinks = [
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/catalogo/libros', label: 'Libros' },
  { href: '/catalogo/revistas', label: 'Revistas' },
  { href: '/categorias', label: 'Categorías' },
  { href: '/autores', label: 'Autores' },
  { href: '/ayuda', label: 'Ayuda' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-surface border-b border-border">
  <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between gap-8">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0" aria-label="Sapiens — Ir al inicio">
      <span class="font-playfair font-bold text-xl text-text tracking-[0.15em] uppercase">
        Sapiens
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`relative font-inter text-sm font-medium pb-0.5 transition-colors group ${
            currentPath.startsWith(link.href) ? 'text-text' : 'text-text-muted hover:text-text'
          }`}
        >
          {link.label}
          <span
            class={`absolute bottom-0 left-0 h-0.5 bg-accent transition-all duration-150 ${
              currentPath.startsWith(link.href) ? 'w-full' : 'w-0 group-hover:w-full'
            }`}
          ></span>
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <!-- Cart -->
      <a
        href="/carrito"
        class="relative flex items-center justify-center w-10 h-10 text-text hover:text-text-muted transition-colors"
        aria-label="Ver carrito de compras"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span
          id="cart-badge"
          class="absolute -top-1 -right-1 w-4 h-4 bg-[#0D0D0D] text-accent text-[10px] font-bold font-inter flex items-center justify-center rounded-full hidden"
          aria-label="items en carrito"
        >0</span>
      </a>

      <!-- Account -->
      <a
        href="/mi-cuenta"
        class="hidden sm:flex items-center gap-2 font-inter text-sm font-medium text-text hover:text-text-muted transition-colors"
        aria-label="Mi cuenta"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        <span class="hidden md:inline">Mi cuenta</span>
      </a>

      <!-- Hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 text-text"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-[#0D0D0D] flex flex-col justify-center items-center hidden lg:hidden"
  role="dialog"
  aria-label="Menú de navegación móvil"
  aria-modal="true"
>
  <nav class="flex flex-col items-center gap-8" aria-label="Navegación móvil">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="font-playfair text-3xl font-medium text-[#F8F8F5] hover:text-accent transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/carrito"
      class="font-inter text-xl text-[#F8F8F5] hover:text-accent transition-colors mt-4"
    >
      Carrito
    </a>
    <a
      href="/mi-cuenta"
      class="font-inter text-xl text-[#F8F8F5] hover:text-accent transition-colors"
    >
      Mi cuenta
    </a>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
</script>
