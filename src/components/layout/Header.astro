---
import HeaderCart from '../cart/HeaderCart';

const navLinks = [
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/catalogo/libros', label: 'Libros' },
  { href: '/catalogo/revistas', label: 'Revistas' },
  { href: '/categorias', label: 'Categorías' },
  { href: '/autores', label: 'Autores' },
  { href: '/ayuda', label: 'Ayuda' },
];

const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
const isAuthenticated = Boolean(user);
const cartLoginHref = `/iniciar-sesion?next=${encodeURIComponent('/carrito')}`;
---

<header class="sticky top-0 z-50 bg-surface border-b border-border">
  <div class="max-w-[1280px] mx-auto px-6 h-16 flex items-center justify-between gap-8">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0" aria-label="Sapiens — Ir al inicio">
      <span class="font-playfair font-bold text-xl text-text tracking-[0.15em] uppercase">
        Sapiens
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`relative font-inter text-sm font-medium pb-0.5 transition-colors group ${
            currentPath.startsWith(link.href) ? 'text-text' : 'text-text-muted hover:text-text'
          }`}
        >
          {link.label}
          <span
            class={`absolute bottom-0 left-0 h-0.5 bg-accent transition-all duration-150 ${
              currentPath.startsWith(link.href) ? 'w-full' : 'w-0 group-hover:w-full'
            }`}
          ></span>
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <!-- Cart: HeaderCart listens for cart-update through useCart. -->
      <HeaderCart isAuthenticated={isAuthenticated} loginHref={cartLoginHref} client:load />

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        class="flex items-center justify-center w-10 h-10 text-text hover:text-text-muted transition-colors"
        aria-label="Cambiar tema"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Account -->
      <div class="hidden sm:flex items-center gap-3">
        <a
          href={user?.rol === 'ADMIN' ? '/admin' : user ? '/mi-cuenta' : '/iniciar-sesion'}
          class="flex items-center gap-2 font-inter text-sm font-medium text-text hover:text-text-muted transition-colors"
          aria-label={user?.rol === 'ADMIN' ? 'Panel de administracion' : user ? 'Mi cuenta' : 'Iniciar sesion'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          <span class="hidden md:inline">{user?.rol === 'ADMIN' ? 'Admin' : user ? 'Mi cuenta' : 'Ingresar'}</span>
        </a>
        {user && (
          <button
            type="button"
            data-auth-logout
            class="flex items-center justify-center w-10 h-10 text-text hover:text-text-muted transition-colors"
            aria-label="Cerrar sesion"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </button>
        )}
      </div>

      <!-- Hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 text-text"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-primary flex flex-col justify-center items-center hidden lg:hidden"
  role="dialog"
  aria-label="Menú de navegación móvil"
  aria-modal="true"
>
  <nav class="flex flex-col items-center gap-8" aria-label="Navegación móvil">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="font-playfair text-3xl font-medium text-bg hover:text-accent transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/carrito"
      class="font-inter text-xl text-bg hover:text-accent transition-colors mt-4"
    >
      Carrito
    </a>
    <a
      href={user?.rol === 'ADMIN' ? '/admin' : user ? '/mi-cuenta' : '/iniciar-sesion'}
      class="font-inter text-xl text-bg hover:text-accent transition-colors"
    >
      {user?.rol === 'ADMIN' ? 'Admin' : user ? 'Mi cuenta' : 'Ingresar'}
    </a>
    {user && (
      <button
        type="button"
        data-auth-logout
        class="font-inter text-xl text-bg hover:text-accent transition-colors"
      >
        Cerrar sesion
      </button>
    )}
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function updateIcons(isDark: boolean) {
    iconSun?.classList.toggle('hidden', !isDark);
    iconMoon?.classList.toggle('hidden', isDark);
  }

  const isDark = document.documentElement.classList.contains('dark');
  updateIcons(isDark);

  themeToggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const nowDark = root.classList.contains('dark');
    root.classList.remove('dark', 'light');
    root.classList.add(nowDark ? 'light' : 'dark');
    localStorage.setItem('theme', nowDark ? 'light' : 'dark');
    updateIcons(!nowDark);
  });

  document.querySelectorAll('[data-auth-logout]').forEach(button => {
    button.addEventListener('click', async () => {
      button.setAttribute('disabled', 'true');
      try {
        const csrfRes = await fetch('/api/auth/csrf');
        const { csrfToken } = await csrfRes.json();
        await fetch('/api/auth/logout', {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrfToken },
        });
      } finally {
        window.location.href = '/iniciar-sesion';
      }
    });
  });
</script>
