---
interface Props {
  title?: string;
  activeSection?: string;
}

const { title = 'Admin — Sapiens', activeSection = '' } = Astro.props;

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'grid' },
  { href: '/admin/catalogo', label: 'Catálogo', icon: 'book-open' },
  { href: '/admin/libros', label: 'Libros', icon: 'book' },
  { href: '/admin/revistas', label: 'Revistas', icon: 'newspaper' },
  { href: '/admin/categorias', label: 'Categorías', icon: 'tag' },
  { href: '/admin/autores', label: 'Autores', icon: 'user' },
  { href: '/admin/pedidos', label: 'Pedidos', icon: 'package', badge: 3 },
  { href: '/admin/clientes', label: 'Clientes', icon: 'users' },
  { href: '/admin/inventario', label: 'Inventario', icon: 'layers' },
  { href: '/admin/reportes', label: 'Reportes', icon: 'bar-chart' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (stored === 'light') {
          document.documentElement.classList.add('light');
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="font-inter bg-bg text-text min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-[200px] flex-shrink-0 bg-surface border-r border-border flex flex-col min-h-screen sticky top-0 h-screen overflow-y-auto">
      <div class="px-5 py-6 border-b border-border">
        <div class="flex items-start justify-between gap-3">
          <a href="/" aria-label="Ir al sitio principal">
            <span class="font-playfair font-bold text-lg tracking-[0.15em] uppercase text-text">Sapiens</span>
          </a>
          <button
            id="admin-theme-toggle"
            type="button"
            class="flex h-8 w-8 items-center justify-center rounded border border-border text-text hover:bg-bg transition-colors"
            aria-label="Cambiar tema"
          >
            <svg id="admin-icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="admin-icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
        <p class="text-[10px] font-inter text-text-muted uppercase tracking-widest mt-1">Admin</p>
      </div>

      <nav class="flex flex-col py-4 flex-1" aria-label="Navegación admin">
        {navItems.map(item => {
          const isActive = currentPath === item.href || (item.href !== '/admin' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`flex items-center justify-between px-5 py-2.5 text-sm font-inter transition-colors ${
                isActive
                  ? 'bg-primary text-bg font-medium'
                  : 'text-text-muted hover:text-text hover:bg-bg'
              }`}
              aria-current={isActive ? 'page' : undefined}
            >
              <span>{item.label}</span>
              {item.badge && (
                <span class="flex items-center justify-center w-5 h-5 bg-accent text-[#0D0D0D] text-[10px] font-bold rounded-full">
                  {item.badge}
                </span>
              )}
            </a>
          );
        })}
      </nav>

      <div class="px-5 py-4 border-t border-border">
        <a href="/" class="text-xs font-inter text-text-muted hover:text-text transition-colors">
          ← Ver sitio
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-auto">
      <slot />
    </main>
  </body>
</html>

<script>
  const adminThemeToggle = document.getElementById('admin-theme-toggle');
  const adminIconSun = document.getElementById('admin-icon-sun');
  const adminIconMoon = document.getElementById('admin-icon-moon');

  function updateAdminIcons(isDark: boolean) {
    adminIconSun?.classList.toggle('hidden', !isDark);
    adminIconMoon?.classList.toggle('hidden', isDark);
  }

  updateAdminIcons(document.documentElement.classList.contains('dark'));

  adminThemeToggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const nowDark = root.classList.contains('dark');
    root.classList.remove('dark', 'light');
    root.classList.add(nowDark ? 'light' : 'dark');
    localStorage.setItem('theme', nowDark ? 'light' : 'dark');
    updateAdminIcons(!nowDark);
  });
</script>

<style is:global>
  @import '../../styles/tailwind.css';
  @import '../../styles/tokens.css';
</style>
