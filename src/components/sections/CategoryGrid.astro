---
import { findAllCategorias } from '../../lib/repos/categorias.js';

const categorias = await findAllCategorias();

const categoryIcons: Record<string, string> = {
  'Literatura Peruana': '🇵🇪',
  'Literatura Internacional': '🌍',
  'Ciencias y Tecnología': '🔬',
  'Revistas de Actualidad': '📰',
  'Infantil y Juvenil': '🌟',
};

const categorySlug = (name: string) =>
  name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
---

<section class="py-16 lg:py-20 bg-bg">
  <div class="max-w-[1280px] mx-auto px-6">
    <h2 class="font-playfair font-bold text-3xl text-text mb-10">Explora por categoría</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {categorias.map(cat => (
        <a
          href={`/categorias/${categorySlug(cat.nombre_categoria)}`}
          class="flex flex-col items-center gap-3 p-6 bg-surface border border-border rounded hover:border-accent transition-colors duration-150 text-center group"
          aria-label={`Ver libros de ${cat.nombre_categoria}`}
        >
          <span class="text-4xl" aria-hidden="true">{categoryIcons[cat.nombre_categoria] ?? '📚'}</span>
          <span class="font-inter text-sm font-medium text-text group-hover:text-text-muted transition-colors leading-tight">
            {cat.nombre_categoria}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
