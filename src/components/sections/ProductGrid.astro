---
import type { Libro, Revista } from '../../types/index.js';
import ProductCard from '../ui/ProductCard.astro';

interface Props {
  title?: string;
  subtitle?: string;
  items: { producto: Libro | Revista; tipo: 'libro' | 'revista' }[];
  scrollable?: boolean;
  columns?: 2 | 3 | 4;
}

const { title, subtitle, items, scrollable = false, columns = 4 } = Astro.props;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
}[columns];
---

{(title || subtitle) && (
  <div class="mb-6 lg:mb-8">
    {title && <h2 class="font-playfair font-bold text-3xl text-text">{title}</h2>}
    {subtitle && <p class="font-inter text-text-muted text-sm mt-1">{subtitle}</p>}
  </div>
)}

{items.length === 0 ? (
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <span class="text-5xl mb-4" aria-hidden="true">📚</span>
    <p class="font-inter text-text-muted text-base">No encontramos productos con esos filtros.</p>
    <a href="/catalogo" class="mt-4 text-sm font-inter text-text underline hover:no-underline">Limpiar filtros</a>
  </div>
) : scrollable ? (
  <div class="overflow-x-auto -mx-6 px-6 pb-4">
    <div class="flex gap-4 w-max">
      {items.map(({ producto, tipo }) => (
        <div class="w-44 sm:w-52 flex-shrink-0">
          <ProductCard producto={producto} tipo={tipo} />
        </div>
      ))}
    </div>
  </div>
) : (
  <div class={`grid ${gridCols} gap-4 lg:gap-6`}>
    {items.map(({ producto, tipo }) => (
      <ProductCard producto={producto} tipo={tipo} />
    ))}
  </div>
)}
