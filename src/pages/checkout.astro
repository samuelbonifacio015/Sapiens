---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CheckoutWizard from '../components/cart/CheckoutWizard';

---

<BaseLayout title="Checkout — Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Finalizar compra</h1>
    <CheckoutWizard client:load />
  </main>
  <Footer />
</BaseLayout>
