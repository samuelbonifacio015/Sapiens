---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getPedidosByCliente } from '../../lib/db/queries/pedidos';
import { findClienteById } from '../../lib/repos/clientes';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/iniciar-sesion?next=/mi-cuenta');

const pedidos = await getPedidosByCliente(user.id);
const cliente = await findClienteById(user.id);
const recentPedidos = pedidos.slice(0, 3);

const estadoColor: Record<string, string> = {
  pendiente: 'bg-warning/10 text-warning',
  confirmado: 'bg-[#0D0D0D]/10 text-[#0D0D0D]',
  enviado: 'bg-[#0D0D0D]/10 text-[#0D0D0D]',
  entregado: 'bg-success/10 text-success',
  cancelado: 'bg-error/10 text-error',
};
const estadoLabel: Record<string, string> = {
  pendiente: 'Pendiente',
  confirmado: 'Confirmado',
  enviado: 'En camino',
  entregado: 'Entregado',
  cancelado: 'Cancelado',
};

const activeStates = new Set(['pendiente', 'confirmado', 'enviado']);
const deliveredPedidos = pedidos.filter((pedido) => String(pedido.estado).toLowerCase() === 'entregado').length;
const activePedidos = pedidos.filter((pedido) => activeStates.has(String(pedido.estado).toLowerCase())).length;
const totalComprado = pedidos.reduce((sum, pedido) => sum + Number(pedido.total ?? 0), 0);
const lastPedido = pedidos[0];
const displayName = cliente?.nombre_cliente ?? 'Cliente Sapiens';
const formattedSince = cliente?.fecha_registro
  ? new Date(cliente.fecha_registro).toLocaleDateString('es-PE', { month: 'long', year: 'numeric' })
  : 'Cuenta activa';

const statusSummary = [
  { label: 'Pendientes', value: pedidos.filter((pedido) => String(pedido.estado).toLowerCase() === 'pendiente').length },
  { label: 'En preparacion', value: pedidos.filter((pedido) => String(pedido.estado).toLowerCase() === 'confirmado').length },
  { label: 'En camino', value: pedidos.filter((pedido) => String(pedido.estado).toLowerCase() === 'enviado').length },
  { label: 'Entregados', value: deliveredPedidos },
];
---

<BaseLayout title="Mi cuenta - Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <section class="mb-8">
      <p class="font-inter text-xs uppercase tracking-[0.18em] text-text-muted mb-3">Panel de cliente</p>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <div>
          <h1 class="font-playfair font-bold text-4xl text-text">Hola, {displayName}</h1>
          <p class="font-inter text-sm text-text-muted mt-2">
            Tus pedidos, datos de cuenta y accesos de compra en un solo lugar.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/catalogo" class="inline-flex items-center justify-center h-11 px-5 bg-text text-bg text-sm font-inter font-medium rounded hover:opacity-90 transition-opacity">Explorar catalogo</a>
          <a href="/mi-cuenta/pedidos" class="inline-flex items-center justify-center h-11 px-5 border border-border text-text text-sm font-inter font-medium rounded hover:border-text transition-colors">Ver pedidos</a>
        </div>
      </div>
    </section>

    <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-6 mb-10">
      <section class="bg-surface border border-border rounded p-6">
        <div class="flex items-start justify-between gap-6 mb-6">
          <div>
            <h2 class="font-playfair font-bold text-2xl text-text">Datos de cuenta</h2>
            <p class="font-inter text-sm text-text-muted mt-1">{formattedSince}</p>
          </div>
          <span class="px-3 py-1 border border-border rounded text-xs font-inter text-text-muted">{cliente?.rol ?? user.role}</span>
        </div>
        <dl class="grid sm:grid-cols-2 gap-4">
          <div class="border border-border rounded p-4">
            <dt class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Correo</dt>
            <dd class="font-inter text-sm text-text mt-2 break-words">{cliente?.correo ?? 'No disponible'}</dd>
          </div>
          <div class="border border-border rounded p-4">
            <dt class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Telefono</dt>
            <dd class="font-inter text-sm text-text mt-2">{cliente?.telefono ?? 'Pendiente de completar'}</dd>
          </div>
          <div class="sm:col-span-2 border border-border rounded p-4">
            <dt class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Direccion de entrega</dt>
            <dd class="font-inter text-sm text-text mt-2">{cliente?.direccion ?? 'Agrega una direccion antes de tu siguiente compra'}</dd>
          </div>
        </dl>
      </section>

      <section class="grid sm:grid-cols-2 gap-4">
        <div class="bg-surface border border-border rounded p-5">
          <p class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Pedidos activos</p>
          <p class="font-playfair font-bold text-4xl text-text mt-3">{activePedidos}</p>
          <p class="font-inter text-xs text-text-muted mt-2">Seguimiento de compras pendientes</p>
        </div>
        <div class="bg-surface border border-border rounded p-5">
          <p class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Pedidos totales</p>
          <p class="font-playfair font-bold text-4xl text-text mt-3">{pedidos.length}</p>
          <p class="font-inter text-xs text-text-muted mt-2">{deliveredPedidos} entregados</p>
        </div>
        <div class="bg-surface border border-border rounded p-5">
          <p class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Total comprado</p>
          <p class="font-playfair font-bold text-3xl text-text mt-3">S/ {totalComprado.toFixed(2)}</p>
          <p class="font-inter text-xs text-text-muted mt-2">Historial de pedidos propios</p>
        </div>
        <div class="bg-surface border border-border rounded p-5">
          <p class="font-inter text-xs uppercase tracking-[0.12em] text-text-muted">Ultimo pedido</p>
          <p class="font-playfair font-bold text-3xl text-text mt-3">{lastPedido ? `#${lastPedido.id_pedido}` : '-'}</p>
          <p class="font-inter text-xs text-text-muted mt-2">{lastPedido ? (estadoLabel[lastPedido.estado] ?? lastPedido.estado) : 'Aun no hay compras'}</p>
        </div>
      </section>
    </div>

    <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-6">
      <aside class="flex flex-col gap-6">
        <section class="bg-surface border border-border rounded p-6">
          <h2 class="font-playfair font-bold text-xl text-text mb-5">Estado de pedidos</h2>
          <div class="flex flex-col gap-3">
            {statusSummary.map((item) => (
              <div class="flex items-center justify-between gap-4 border border-border rounded px-4 py-3">
                <span class="font-inter text-sm text-text-muted">{item.label}</span>
                <span class="font-inter text-sm font-semibold text-text">{item.value}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="bg-text text-bg rounded p-6">
          <p class="font-inter text-xs uppercase tracking-[0.16em] opacity-70">Accesos</p>
          <h2 class="font-playfair font-bold text-2xl mt-3">Continua tu lectura</h2>
          <div class="flex flex-col gap-3 mt-5">
            <a href="/catalogo" class="inline-flex items-center justify-between h-11 px-4 border border-bg/25 rounded text-sm font-inter hover:bg-bg hover:text-text transition-colors">Catalogo <span aria-hidden="true">+</span></a>
            <a href="/ayuda" class="inline-flex items-center justify-between h-11 px-4 border border-bg/25 rounded text-sm font-inter hover:bg-bg hover:text-text transition-colors">Centro de ayuda <span aria-hidden="true">+</span></a>
          </div>
        </section>
      </aside>

      <section class="bg-surface border border-border rounded p-6">
        <div class="flex items-center justify-between gap-4 mb-5">
          <h2 class="font-playfair font-bold text-xl text-text">Pedidos recientes</h2>
          <a href="/mi-cuenta/pedidos" class="font-inter text-sm text-text-muted underline hover:text-text transition-colors">Ver todos</a>
        </div>
        {recentPedidos.length === 0 ? (
          <div class="min-h-[260px] flex flex-col items-center justify-center text-center border border-dashed border-border rounded px-6">
            <p class="font-playfair font-bold text-2xl text-text">Tu historial esta listo para empezar</p>
            <p class="font-inter text-sm text-text-muted mt-3 max-w-md">Cuando compres durante una feria o campana especial, tus pedidos apareceran aqui con su estado actualizado.</p>
            <div class="flex flex-wrap justify-center gap-3 mt-6">
              <a href="/catalogo" class="inline-flex items-center justify-center h-10 px-4 bg-text text-bg text-sm font-inter font-medium rounded hover:opacity-90 transition-opacity">Explorar catalogo</a>
              <a href="/ayuda" class="inline-flex items-center justify-center h-10 px-4 border border-border text-text text-sm font-inter font-medium rounded hover:border-text transition-colors">Resolver dudas</a>
            </div>
          </div>
        ) : (
          <div class="flex flex-col divide-y divide-border border border-border rounded overflow-hidden">
            {recentPedidos.map(pedido => (
              <a href={`/mi-cuenta/pedidos/${pedido.id_pedido}`} class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-4 hover:bg-bg transition-colors group">
                <div>
                  <p class="font-inter font-medium text-text text-sm">Pedido #{pedido.id_pedido}</p>
                  <p class="font-inter text-xs text-text-muted mt-0.5">{new Date(pedido.fecha).toLocaleString()}</p>
                </div>
                <div class="flex items-center gap-4">
                  <span class="font-inter font-bold text-text text-sm">S/ {pedido.total.toFixed(2)}</span>
                  <span class={`px-2.5 py-1 text-xs font-inter font-medium rounded ${estadoColor[pedido.estado] ?? 'bg-surface text-text'}`}>
                    {estadoLabel[pedido.estado] ?? pedido.estado}
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
