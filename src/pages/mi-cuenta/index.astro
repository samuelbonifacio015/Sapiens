---

<BaseLayout title="Mi cuenta — Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Mi cuenta</h1>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <a href="/mi-cuenta/pedidos" class="flex flex-col gap-2 p-6 bg-surface border border-border rounded hover:border-[#0D0D0D] transition-colors group">
        <span class="text-2xl" aria-hidden="true">📦</span>
        <h2 class="font-inter font-medium text-text group-hover:underline">Mis pedidos</h2>
        <p class="font-inter text-xs text-text-muted">{pedidos.length} pedidos realizados</p>
      </a>
      <a href="/catalogo" class="flex flex-col gap-2 p-6 bg-surface border border-border rounded hover:border-[#0D0D0D] transition-colors group">
        <span class="text-2xl" aria-hidden="true">📚</span>
        <h2 class="font-inter font-medium text-text group-hover:underline">Explorar catálogo</h2>
        <p class="font-inter text-xs text-text-muted">Libros y revistas</p>
      </a>
      <a href="/ayuda" class="flex flex-col gap-2 p-6 bg-surface border border-border rounded hover:border-[#0D0D0D] transition-colors group">
        <span class="text-2xl" aria-hidden="true">💬</span>
        <h2 class="font-inter font-medium text-text group-hover:underline">Centro de ayuda</h2>
        <p class="font-inter text-xs text-text-muted">Envíos, pagos y más</p>
      </a>
    </div>

    <section>
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-playfair font-bold text-xl text-text">Pedidos recientes</h2>
        <a href="/mi-cuenta/pedidos" class="font-inter text-sm text-text-muted underline hover:text-text transition-colors">Ver todos</a>
      </div>
      {recentPedidos.length === 0 ? (
        <div class="py-12 text-center">
          <p class="font-inter text-text-muted">No has realizado pedidos aún.</p>
          <a href="/catalogo" class="mt-3 inline-block text-sm font-inter text-text underline">Empezar a comprar</a>
        </div>
      ) : (
        <div class="flex flex-col divide-y divide-border border border-border rounded overflow-hidden">
          {recentPedidos.map(pedido => (
            <a href={`/mi-cuenta/pedidos/${pedido.id_pedido}`} class="flex items-center justify-between p-4 hover:bg-bg transition-colors group">
              <div>
                <p class="font-inter font-medium text-text text-sm">Pedido #{pedido.id_pedido}</p>
                <p class="font-inter text-xs text-text-muted mt-0.5">{new Date(pedido.fecha_pedido).toLocaleString()}</p>
              </div>
              <div class="flex items-center gap-4">
                <span class="font-inter font-bold text-text text-sm">S/ {pedido.total.toFixed(2)}</span>
                <span class={`px-2.5 py-1 text-xs font-inter font-medium rounded ${estadoColor[pedido.estado] ?? 'bg-surface text-text'}`}>
                  {pedido.estado}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
