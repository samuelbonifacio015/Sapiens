---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import StockIndicator from '../../components/ui/StockIndicator.astro';
import Badge from '../../components/ui/Badge.astro';
import ProductCard from '../../components/ui/ProductCard.astro';
import { getRevistaById, getRevistasByCategoria } from '../../lib/db/queries/revistas';
import { getMagazineCoverSrc } from '../../lib/magazine-covers.js';

const id = Number(Astro.params.id);
const revista = await getRevistaById(id);
if (!revista) return Astro.redirect('/catalogo/revistas');

const related = (await getRevistasByCategoria(revista.id_categoria))
  .filter(r => r.id_revista !== revista.id_revista)
  .slice(0, 4)
  .map(r => ({ producto: r, tipo: 'revista' as const }));

const coverSrc = getMagazineCoverSrc(revista);
---

<BaseLayout title={`${revista.titulo} — Sapiens`}>
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <nav class="flex items-center gap-2 text-xs font-inter text-text-muted mb-8 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text transition-colors">Inicio</a>
      <span aria-hidden="true">/</span>
      <a href="/catalogo/revistas" class="hover:text-text transition-colors">Revistas</a>
      <span aria-hidden="true">/</span>
      <span class="text-text" aria-current="page">{revista.titulo}</span>
    </nav>

    <div class="grid md:grid-cols-5 gap-10 lg:gap-16">
      <div class="md:col-span-2">
        <div class="relative">
          <Badge variant="default" class="absolute top-3 left-3 z-10">
            {revista.categoria?.nombre_categoria}
          </Badge>
          <div class="aspect-[3/4] w-full rounded border border-border overflow-hidden bg-[#F4F1EA]">
            {coverSrc ? (
              <img
                src={coverSrc}
                alt={`Portada de ${revista.titulo}`}
                class="h-full w-full object-cover"
                loading="eager"
                decoding="async"
              />
            ) : (
              <div
                class="h-full w-full bg-[#F4F1EA]"
                role="img"
                aria-label={`Portada no disponible para ${revista.titulo}`}
              ></div>
            )}
          </div>
        </div>
      </div>

      <div class="md:col-span-3 flex flex-col gap-5">
        <div>
          <h1 class="font-playfair font-bold text-3xl lg:text-4xl text-text leading-tight">{revista.titulo}</h1>
          {revista.frecuencia && (
            <p class="mt-2 font-inter text-text-muted text-sm uppercase tracking-wide">{revista.frecuencia}</p>
          )}
        </div>

        <div class="flex items-center gap-4">
          <span class="font-inter font-bold text-3xl text-text">S/ {revista.precio.toFixed(2)}</span>
          <StockIndicator stock={revista.stock} showCount={true} />
        </div>

        <table class="text-sm font-inter border-collapse">
          <tbody>
            {[
              ['ISSN', revista.issn],
              ['Editorial', revista.editorial],
              ['Frecuencia', revista.frecuencia],
              ['Categoría', revista.categoria?.nombre_categoria],
            ].map(([key, val]) => val && (
              <tr class="border-b border-border">
                <td class="py-2 pr-6 text-text-muted w-1/2">{key}</td>
                <td class="py-2 text-text">{val}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="flex flex-col gap-3 pt-2">
          <button
            type="button"
            disabled={revista.stock === 0}
            aria-label={revista.stock === 0 ? 'Sin stock' : `Agregar ${revista.titulo} al carrito`}
            class="w-full py-4 bg-[#0D0D0D] text-[#F8F8F5] font-inter font-medium text-sm rounded hover:bg-[#1A1A1A] transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          >
            {revista.stock === 0 ? 'Sin stock' : 'Agregar al carrito'}
          </button>
        </div>
      </div>
    </div>

    {related.length > 0 && (
      <section class="mt-16 pt-12 border-t border-border">
        <h2 class="font-playfair font-bold text-2xl text-text mb-8">
          También en {revista.categoria?.nombre_categoria}
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
          {related.map(({ producto, tipo }) => (
            <ProductCard producto={producto} tipo={tipo} />
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>
