---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ProductCard from '../../components/ui/ProductCard.astro';
import FilterSidebar from '../../components/sections/FilterSidebar';
import { getRevistas } from '../../lib/db/queries/revistas';
import { getCategorias } from '../../lib/db/queries/categorias';
import { applyCatalogFilters, parseCatalogFilters } from '../../lib/catalog-filters';

const [revistas, categorias] = await Promise.all([getRevistas(), getCategorias()]);
const allItems = revistas.map(revista => ({ producto: revista, tipo: 'revista' as const }));

const categoriasWithCount = categorias.map(cat => ({
  ...cat,
  count: revistas.filter(r => r.id_categoria === cat.id_categoria).length,
}));

const filters = parseCatalogFilters(Astro.url.searchParams, new Set(categorias.map(cat => cat.id_categoria)));
const filteredItems = applyCatalogFilters(allItems, filters);
---

<BaseLayout title="Revistas — Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <div class="mb-6">
      <nav class="flex items-center gap-2 text-xs font-inter text-text-muted mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-text transition-colors">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/catalogo" class="hover:text-text transition-colors">Catálogo</a>
        <span aria-hidden="true">/</span>
        <span class="text-text" aria-current="page">Revistas</span>
      </nav>
      <h1 class="font-playfair font-bold text-4xl text-text">Revistas</h1>
      <p class="font-inter text-text-muted text-sm mt-2">{revistas.length} títulos disponibles</p>
    </div>

    <div class="flex gap-10 items-start">
      <FilterSidebar categorias={categoriasWithCount} client:load />
      <div class="flex-1 min-w-0">
        {filteredItems.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-20 text-center">
            <p class="font-inter text-text-muted text-base">No encontramos productos con esos filtros.</p>
          </div>
        ) : (
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
            {filteredItems.map(({ producto }) => (
              <ProductCard producto={producto} tipo="revista" />
            ))}
          </div>
        )}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
