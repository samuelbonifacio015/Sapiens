---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SearchResults from '../components/sections/SearchResults';
import { getLibros } from '../lib/db/queries/libros';
import { getRevistas } from '../lib/db/queries/revistas';

const libros = await getLibros();
const revistas = await getRevistas();
---

<BaseLayout title="Buscar — Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <h1 class="font-playfair font-bold text-3xl text-text mb-6">Buscar</h1>
    <SearchResults libros={libros} revistas={revistas} client:load />
  </main>
  <Footer />
</BaseLayout>
