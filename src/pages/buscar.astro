---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SearchResults from '../components/sections/SearchResults';
import { libros } from '../lib/mocks/libros.js';
import { revistas } from '../lib/mocks/revistas.js';
---

<BaseLayout title="Buscar — Sapiens">
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <h1 class="font-playfair font-bold text-3xl text-text mb-6">Buscar</h1>
    <SearchResults libros={libros} revistas={revistas} client:load />
  </main>
  <Footer />
</BaseLayout>
