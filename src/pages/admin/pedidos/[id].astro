---
import AdminLayout from '../../../components/layout/AdminLayout.astro';
import { getPedidoById } from '../../../lib/db/queries/pedidos';
import { getLibros } from '../../../lib/db/queries/libros';
import { getRevistas } from '../../../lib/db/queries/revistas';

const id = Number(Astro.params.id);
const [pedido, libros, revistas] = await Promise.all([getPedidoById(id), getLibros(), getRevistas()]);
if (!pedido) return Astro.redirect('/admin/pedidos');

const ESTADOS = ['Pendiente', 'Confirmado', 'En camino', 'Entregado', 'Cancelado'];
const estadoColor: Record<string, string> = {
  pendiente: 'bg-warning text-[#0D0D0D]',
  confirmado: 'bg-[#0D0D0D] text-[#F8F8F5]',
  enviado: 'bg-[#0D0D0D] text-[#F8F8F5]',
  entregado: 'bg-success text-white',
  cancelado: 'bg-error text-white',
};
const estadoLabel: Record<string, string> = {
  pendiente: 'Pendiente', confirmado: 'Confirmado', enviado: 'En camino', entregado: 'Entregado', cancelado: 'Cancelado',
};
---

<AdminLayout title={`Pedido #${pedido.id_pedido} — Admin`}>
  <div class="p-8 max-w-3xl">
    <nav class="flex items-center gap-2 text-xs font-inter text-text-muted mb-6" aria-label="Breadcrumb">
      <a href="/admin" class="hover:text-text transition-colors">Dashboard</a>
      <span aria-hidden="true">/</span>
      <a href="/admin/pedidos" class="hover:text-text transition-colors">Pedidos</a>
      <span aria-hidden="true">/</span>
      <span class="text-text" aria-current="page">#{pedido.id_pedido}</span>
    </nav>

    <div class="flex items-center justify-between gap-4 mb-8">
      <h1 class="font-playfair font-bold text-3xl text-text">Pedido #{pedido.id_pedido}</h1>
      <span class={`px-3 py-1.5 text-xs font-inter font-semibold rounded ${estadoColor[pedido.estado] ?? 'bg-surface text-text'}`}>
        {estadoLabel[pedido.estado] ?? pedido.estado}
      </span>
    </div>

    <form id="estado-form" class="bg-surface border border-border rounded p-5 mb-6 flex items-center gap-3" data-id={pedido.id_pedido}>
      <label class="font-inter text-sm text-text" for="estado-select">Cambiar estado:</label>
      <select id="estado-select" class="border border-border rounded px-3 py-2 text-sm bg-bg">
        {ESTADOS.map(e => <option value={e} selected={e === pedido.estado}>{e}</option>)}
      </select>
      <button type="submit" class="px-4 py-2 bg-[#0D0D0D] text-[#F8F8F5] text-sm rounded">Guardar</button>
      <span id="estado-msg" class="text-xs font-inter text-text-muted"></span>
    </form>

    <div class="grid sm:grid-cols-2 gap-6 mb-8">
      {pedido.cliente && (
        <div class="bg-surface border border-border rounded p-5">
          <h2 class="font-inter font-semibold text-text text-sm mb-3">Cliente</h2>
          <p class="font-inter text-sm text-text">{pedido.cliente.nombre}</p>
          <p class="font-inter text-sm text-text-muted">{pedido.cliente.email}</p>
        </div>
      )}
      <div class="bg-surface border border-border rounded p-5">
        <h2 class="font-inter font-semibold text-text text-sm mb-3">Detalles</h2>
        <p class="font-inter text-sm text-text-muted">Fecha: {new Date(pedido.fecha).toLocaleString()}</p>
        <p class="font-inter text-sm text-text-muted">Total: <strong class="text-text">S/ {pedido.total.toFixed(2)}</strong></p>
      </div>
    </div>

    <div class="bg-surface border border-border rounded overflow-hidden">
      <div class="px-5 py-4 border-b border-border">
        <h2 class="font-inter font-semibold text-text text-sm">Productos</h2>
      </div>
      <div class="divide-y divide-border">
        {(pedido.detalles ?? []).map(detalle => (
          <div class="flex items-center justify-between px-5 py-4">
            <div>
              <p class="font-inter text-sm text-text">{detalle.id_libro ? (libros.find(l => l.id_libro === detalle.id_libro)?.titulo ?? `Libro #${detalle.id_libro}`) : (revistas.find(r => r.id_revista === detalle.id_revista)?.titulo ?? `Revista #${detalle.id_revista}`)}</p>
              <p class="font-inter text-xs text-text-muted">{detalle.id_libro ? 'Libro' : 'Revista'} × {detalle.cantidad}</p>
            </div>
            <span class="font-inter font-medium text-text text-sm">
              S/ {(detalle.precio_unitario * detalle.cantidad).toFixed(2)}
            </span>
          </div>
        ))}
      </div>
      <div class="px-5 py-4 border-t border-border flex items-center justify-between">
        <span class="font-inter font-semibold text-text">Total</span>
        <span class="font-inter font-bold text-xl text-text">S/ {pedido.total.toFixed(2)}</span>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('estado-form') as HTMLFormElement | null;
  if (form) {
    const id = form.dataset.id;
    const sel = document.getElementById('estado-select') as HTMLSelectElement;
    const msg = document.getElementById('estado-msg')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.textContent = 'Guardando...';
      const csrfRes = await fetch('/api/auth/csrf');
      const { csrfToken } = await csrfRes.json();
      const res = await fetch(`/api/pedidos/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ estado: sel.value }),
      });
      msg.textContent = res.ok ? 'Guardado' : 'Error';
      if (res.ok) setTimeout(() => location.reload(), 500);
    });
  }
</script>
