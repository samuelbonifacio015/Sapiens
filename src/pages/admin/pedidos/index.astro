---
import AdminLayout from '../../../components/layout/AdminLayout.astro';
import { pedidos } from '../../../lib/mocks/pedidos.js';

const estadoColor: Record<string, string> = {
  pendiente: 'bg-warning/10 text-warning',
  confirmado: 'bg-[#0D0D0D]/10 text-[#0D0D0D]',
  enviado: 'bg-[#0D0D0D]/10 text-[#0D0D0D]',
  entregado: 'bg-success/10 text-success',
  cancelado: 'bg-error/10 text-error',
};
---

<AdminLayout title="Pedidos — Admin Sapiens">
  <div class="p-8">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Pedidos</h1>
    <div class="bg-surface border border-border rounded overflow-hidden">
      <table class="w-full text-sm font-inter">
        <thead>
          <tr class="border-b border-border bg-bg">
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider"># Pedido</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider hidden md:table-cell">Cliente</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Total</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Estado</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider hidden sm:table-cell">Fecha</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {pedidos.map(pedido => (
            <tr class="hover:bg-bg transition-colors">
              <td class="px-4 py-3">
                <a href={`/admin/pedidos/${pedido.id_pedido}`} class="text-text font-medium hover:underline">#{pedido.id_pedido}</a>
              </td>
              <td class="px-4 py-3 text-text-muted hidden md:table-cell">{pedido.cliente?.nombre ?? '—'}</td>
              <td class="px-4 py-3 text-text font-medium">S/ {pedido.total.toFixed(2)}</td>
              <td class="px-4 py-3">
                <span class={`px-2.5 py-1 text-xs font-medium rounded capitalize ${estadoColor[pedido.estado]}`}>{pedido.estado}</span>
              </td>
              <td class="px-4 py-3 text-text-muted hidden sm:table-cell">{pedido.fecha}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
