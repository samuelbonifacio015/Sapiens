---
import AdminLayout from '../../components/layout/AdminLayout.astro';
import { getPedidos, getClientes } from '../../lib/db/queries/pedidos';
import { getLibros, getLowStockLibros } from '../../lib/db/queries/libros';
import { getRevistas, getLowStockRevistas } from '../../lib/db/queries/revistas';

const today = new Date().toISOString().split('T')[0];
const [pedidos, lowLibros, lowRevistas, todosClientes, libros, revistas] = await Promise.all([
  getPedidos(),
  getLowStockLibros(5),
  getLowStockRevistas(5),
  getClientes(),
  getLibros(),
  getRevistas(),
]);

const pedidosHoy = pedidos.filter(p => p.fecha === today).length;
const pedidosPendientes = pedidos.filter(p => p.estado === 'pendiente' || p.estado === 'confirmado').length;
const pedidosActivos = pedidos.filter(p => p.estado !== 'cancelado');
const ingresosActivos = pedidosActivos.reduce((sum, p) => sum + p.total, 0);
const stockCritico = lowLibros.length + lowRevistas.length;
const catalogoTotal = libros.length + revistas.length;
const recentPedidos = pedidos.slice(0, 8);
const lowStockItems = [
  ...lowLibros.map(l => ({ titulo: l.titulo, stock: l.stock, tipo: 'Libro' })),
  ...lowRevistas.map(r => ({ titulo: r.titulo, stock: r.stock, tipo: 'Revista' })),
].sort((a, b) => a.stock - b.stock).slice(0, 8);

const kpis = [
  { label: 'Pedidos hoy', value: pedidosHoy, note: 'Carga diaria' },
  { label: 'Pedidos activos', value: pedidosPendientes, note: 'Pendiente o confirmado' },
  { label: 'Stock critico', value: stockCritico, note: '5 unidades o menos' },
  { label: 'Catalogo visible', value: catalogoTotal, note: `${libros.length} libros, ${revistas.length} revistas` },
  { label: 'Clientes', value: todosClientes.length, note: 'Cuentas registradas' },
  { label: 'Ingresos activos', value: `S/ ${ingresosActivos.toFixed(0)}`, note: 'Sin cancelados' },
];

const readiness = [
  { label: 'Sesion JWT', state: 'Listo', detail: 'Cookie httpOnly, rol USER/ADMIN y JWT_SECRET obligatorio en produccion.', tone: 'success' },
  { label: 'Rutas privadas', state: 'Listo', detail: '/admin, /mi-cuenta y /checkout pasan por middleware.', tone: 'success' },
  { label: 'CSRF', state: 'Listo', detail: 'Mutaciones usan token de doble envio con cookie legible.', tone: 'success' },
  { label: 'Pool MySQL', state: 'Vigilar', detail: 'connectionLimit 10 sirve para demo, no para 8,000 concurrentes.', tone: 'warning' },
  { label: 'TLS DB', state: 'Pendiente', detail: 'Falta configurar SSL/TLS hacia MySQL administrado.', tone: 'warning' },
  { label: 'Backups', state: 'Pendiente', detail: 'Falta runbook de snapshots diarios y retencion Azure Blob.', tone: 'warning' },
  { label: 'Cifrado reposo', state: 'Pendiente', detail: 'Debe quedar cubierto por Azure Database for MySQL.', tone: 'warning' },
];

const estadoColor: Record<string, string> = {
  pendiente: 'bg-warning/10 text-warning border-warning/20',
  confirmado: 'bg-primary/10 text-text border-border',
  enviado: 'bg-primary/10 text-text border-border',
  entregado: 'bg-success/10 text-success border-success/20',
  cancelado: 'bg-error/10 text-error border-error/20',
};
const estadoLabel: Record<string, string> = {
  pendiente: 'Pendiente',
  confirmado: 'Confirmado',
  enviado: 'En camino',
  entregado: 'Entregado',
  cancelado: 'Cancelado',
};
const readinessStyle: Record<string, string> = {
  success: 'border-success/30 bg-success/10 text-success',
  warning: 'border-warning/30 bg-warning/10 text-warning',
};
---

<AdminLayout title="Dashboard - Admin Sapiens">
  <div class="p-6 lg:p-8">
    <div class="mb-8 flex flex-col gap-3 border-b border-border pb-6">
      <p class="font-inter text-xs font-semibold uppercase tracking-[0.22em] text-text-muted">Seguridad y escala</p>
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="font-playfair font-bold text-3xl text-text">Centro de control Sapiens</h1>
          <p class="mt-2 max-w-3xl font-inter text-sm leading-6 text-text-muted">
            Lectura operativa para campanas de alta demanda: pedidos, stock, capacidad y controles exigidos por el informe.
          </p>
        </div>
        <div class="border border-border bg-surface px-4 py-3 text-sm font-inter text-text">
          Objetivo pico: <strong>8,000 usuarios</strong> / 133 ops/s
        </div>
      </div>
    </div>

    <section class="mb-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-6" aria-label="Indicadores operativos">
      {kpis.map(kpi => (
        <div class="border border-border bg-surface p-4">
          <p class="font-inter text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">{kpi.label}</p>
          <p class="mt-3 font-inter text-2xl font-bold text-text">{kpi.value}</p>
          <p class="mt-1 font-inter text-xs text-text-muted">{kpi.note}</p>
        </div>
      ))}
    </section>

    <div class="grid gap-8 xl:grid-cols-[1.25fr_0.75fr]">
      <section>
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="font-inter text-base font-semibold text-text">Pedidos recientes</h2>
          <a href="/admin/pedidos" class="font-inter text-xs text-text-muted underline underline-offset-4 hover:text-text">Ver todos</a>
        </div>
        <div class="overflow-hidden border border-border bg-surface">
          <table class="w-full min-w-[680px] text-sm font-inter">
            <thead>
              <tr class="border-b border-border bg-bg">
                <th class="px-4 py-3 text-left text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">Pedido</th>
                <th class="px-4 py-3 text-left text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">Cliente</th>
                <th class="px-4 py-3 text-left text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">Total</th>
                <th class="px-4 py-3 text-left text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">Estado</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {recentPedidos.map(pedido => (
                <tr class="hover:bg-bg transition-colors">
                  <td class="px-4 py-3">
                    <a href={`/admin/pedidos/${pedido.id_pedido}`} class="font-medium text-text hover:underline">#{pedido.id_pedido}</a>
                    <p class="mt-1 text-xs text-text-muted">{new Date(pedido.fecha).toLocaleDateString()}</p>
                  </td>
                  <td class="px-4 py-3 text-text-muted">{pedido.cliente?.nombre ?? 'Sin cliente'}</td>
                  <td class="px-4 py-3 font-medium text-text">S/ {pedido.total.toFixed(2)}</td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex rounded border px-2.5 py-1 text-xs font-medium ${estadoColor[pedido.estado] ?? 'border-border bg-bg text-text'}`}>
                      {estadoLabel[pedido.estado] ?? pedido.estado}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="font-inter text-base font-semibold text-text">Inventario critico</h2>
          <a href="/admin/inventario" class="font-inter text-xs text-text-muted underline underline-offset-4 hover:text-text">Inventario</a>
        </div>
        <div class="border border-border bg-surface">
          {lowStockItems.length === 0 ? (
            <div class="p-6">
              <p class="font-inter text-sm font-medium text-text">Sin alertas de stock</p>
              <p class="mt-1 font-inter text-xs text-text-muted">No hay productos por debajo del umbral actual.</p>
            </div>
          ) : (
            <div class="divide-y divide-border">
              {lowStockItems.map(item => (
                <div class="flex items-center justify-between gap-4 px-4 py-3">
                  <div class="min-w-0">
                    <p class="truncate font-inter text-sm font-medium text-text">{item.titulo}</p>
                    <p class="mt-1 font-inter text-xs text-text-muted">{item.tipo}</p>
                  </div>
                  <span class="font-inter text-sm font-bold text-warning">{item.stock}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    </div>

    <section class="mt-8">
      <div class="mb-4 flex flex-col gap-1">
        <h2 class="font-inter text-base font-semibold text-text">Readiness del informe</h2>
        <p class="font-inter text-sm text-text-muted">Estado visible de los controles necesarios para escalar y proteger Sapiens.</p>
      </div>
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {readiness.map(item => (
          <article class="border border-border bg-surface p-4">
            <div class="flex items-center justify-between gap-3">
              <h3 class="font-inter text-sm font-semibold text-text">{item.label}</h3>
              <span class={`inline-flex rounded border px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] ${readinessStyle[item.tone]}`}>
                {item.state}
              </span>
            </div>
            <p class="mt-3 font-inter text-sm leading-6 text-text-muted">{item.detail}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</AdminLayout>
