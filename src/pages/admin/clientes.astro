---
import AdminLayout from '../../components/layout/AdminLayout.astro';
import { getClientes } from '../../lib/db/queries/pedidos';

const clientes = await getClientes();
---

<AdminLayout title="Clientes — Admin Sapiens">
  <div class="p-8">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Clientes</h1>
    <div class="bg-surface border border-border rounded overflow-hidden">
      <table class="w-full text-sm font-inter">
        <thead>
          <tr class="border-b border-border bg-bg">
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Nombre</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Correo</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider hidden md:table-cell">Teléfono</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Rol</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Pedidos</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {clientes.map(cliente => (
            <tr class="hover:bg-bg transition-colors">
              <td class="px-4 py-3 font-inter font-medium text-text">{cliente.nombre}</td>
              <td class="px-4 py-3 text-text-muted">{cliente.email}</td>
              <td class="px-4 py-3 text-text-muted hidden md:table-cell">{cliente.telefono ?? '—'}</td>
              <td class="px-4 py-3 text-text-muted">USER</td>
              <td class="px-4 py-3 text-text-muted">—</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
