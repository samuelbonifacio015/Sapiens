---
import AdminLayout from '../../components/layout/AdminLayout.astro';
import { getAutores } from '../../lib/db/queries/autores';
import { getLibros } from '../../lib/db/queries/libros';

const [autores, libros] = await Promise.all([getAutores(), getLibros()]);
---

<AdminLayout title="Autores — Admin Sapiens">
  <div class="p-8">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Autores</h1>
    <div class="bg-surface border border-border rounded overflow-hidden">
      <table class="w-full text-sm font-inter">
        <thead>
          <tr class="border-b border-border bg-bg">
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Nombre</th>
            <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Libros</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {autores.map(autor => (
            <tr class="hover:bg-bg transition-colors">
              <td class="px-4 py-3">
                <a href={`/autores/${autor.id_autor}`} class="font-inter font-medium text-text hover:underline">{autor.nombre_autor}</a>
                {autor.bio && <p class="font-inter text-xs text-text-muted mt-0.5 line-clamp-1">{autor.bio}</p>}
              </td>
              <td class="px-4 py-3 text-text-muted">
                {libros.filter(l => l.id_autor === autor.id_autor).length}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
