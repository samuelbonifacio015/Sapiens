---
import AdminLayout from '../../components/layout/AdminLayout.astro';
import { getPedidos } from '../../lib/db/queries/pedidos';
import { getLibros } from '../../lib/db/queries/libros';

const [pedidos, libros] = await Promise.all([getPedidos(), getLibros()]);

const activos = pedidos.filter(p => p.estado !== 'cancelado');
const ingresosTotales = activos.reduce((s, p) => s + p.total, 0);
const ticketPromedio = ingresosTotales / Math.max(activos.length, 1);
const topLibros = [...libros].sort((a, b) => b.stock - a.stock).slice(0, 5);
---

<AdminLayout title="Reportes — Admin Sapiens">
  <div class="p-8">
    <h1 class="font-playfair font-bold text-3xl text-text mb-8">Reportes</h1>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
      {[
        { label: 'Ingresos totales', value: `S/ ${ingresosTotales.toFixed(2)}` },
        { label: 'Ticket promedio', value: `S/ ${ticketPromedio.toFixed(2)}` },
        { label: 'Pedidos totales', value: pedidos.length },
        { label: 'Entregados', value: pedidos.filter(p => p.estado === 'entregado').length },
        { label: 'Cancelados', value: pedidos.filter(p => p.estado === 'cancelado').length },
        { label: 'Pendientes', value: pedidos.filter(p => p.estado === 'pendiente').length },
      ].map(s => (
        <div class="bg-surface border border-border rounded p-5">
          <p class="font-inter font-bold text-2xl text-text">{s.value}</p>
          <p class="font-inter text-xs text-text-muted mt-1">{s.label}</p>
        </div>
      ))}
    </div>
    <section>
      <h2 class="font-playfair font-bold text-xl text-text mb-4">Libros con más stock</h2>
      <div class="bg-surface border border-border rounded overflow-hidden">
        <table class="w-full text-sm font-inter">
          <thead>
            <tr class="border-b border-border bg-bg">
              <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Libro</th>
              <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Precio</th>
              <th class="text-left px-4 py-3 text-text-muted font-medium text-xs uppercase tracking-wider">Stock</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {topLibros.map(libro => (
              <tr class="hover:bg-bg transition-colors">
                <td class="px-4 py-3 font-inter font-medium text-text">{libro.titulo}</td>
                <td class="px-4 py-3 text-text-muted">S/ {libro.precio.toFixed(2)}</td>
                <td class="px-4 py-3 text-text-muted">{libro.stock}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout>
