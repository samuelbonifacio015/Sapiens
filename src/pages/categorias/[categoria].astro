---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ProductCard from '../../components/ui/ProductCard.astro';
import { getCategoriaBySlug } from '../../lib/db/queries/categorias';
import { getLibrosByCategoria } from '../../lib/db/queries/libros';
import { getRevistasByCategoria } from '../../lib/db/queries/revistas';

const { categoria: slug } = Astro.params;
const categoria = await getCategoriaBySlug(slug!);
if (!categoria) return Astro.redirect('/categorias');

const [librosItems, revistasItems] = await Promise.all([
  getLibrosByCategoria(categoria.id_categoria).then(ls => ls.map(l => ({ producto: l, tipo: 'libro' as const }))),
  getRevistasByCategoria(categoria.id_categoria).then(rs => rs.map(r => ({ producto: r, tipo: 'revista' as const }))),
]);

const allItems = [...librosItems, ...revistasItems];
---

<BaseLayout title={`${categoria.nombre_categoria} — Sapiens`}>
  <Header />
  <main class="max-w-[1280px] mx-auto px-6 py-10">
    <nav class="flex items-center gap-2 text-xs font-inter text-text-muted mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text transition-colors">Inicio</a>
      <span aria-hidden="true">/</span>
      <a href="/categorias" class="hover:text-text transition-colors">Categorías</a>
      <span aria-hidden="true">/</span>
      <span class="text-text" aria-current="page">{categoria.nombre_categoria}</span>
    </nav>

    <h1 class="font-playfair font-bold text-4xl text-text mb-2">{categoria.nombre_categoria}</h1>
    <p class="font-inter text-text-muted text-sm mb-10">{allItems.length} productos</p>

    {allItems.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <span class="text-5xl mb-4" aria-hidden="true">📚</span>
        <p class="font-inter text-text-muted text-base">No hay productos en esta categoría.</p>
        <a href="/catalogo" class="mt-4 text-sm font-inter text-text underline hover:no-underline">Ver todo el catálogo</a>
      </div>
    ) : (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
        {allItems.map(({ producto, tipo }) => (
          <ProductCard producto={producto} tipo={tipo} />
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
